# === LLM ===
GROQ_API_KEY=your_groq_api_key_here

# === Observability ===
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=spain-rec

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=spain-rec-1234

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=spain_rec
POSTGRES_USER=spain_rec
POSTGRES_PASSWORD=spain-rec-1234
DATABASE_URL=postgresql://spain_rec:spain-rec-1234@localhost:5432/spain_rec

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_PORT=6333

# === Pinecone (cloud demo mode) ===
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=us-east-1

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# === Vector store selector ===
# Options: qdrant | pinecone
VECTOR_STORE=qdrant

# === FastAPI ===
API_HOST=0.0.0.0
API_PORT=8000

# === n8n ===
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=spain-rec-1234
